# Provy proof-simulation harness — environment.
# Copy to .env and fill in. NOTHING is emitted unless PROVY_EMIT is truthy AND a
# key is present, so a dry run with this file empty is safe.

# Provy ingest endpoint (default is production; leave as-is normally)
PROVY_URL=https://provyai.vercel.app

# One ingest key per workflow (fleet). A key resolves (tenant_id, workflow_id).
# Get these from the onboarding wizard after signup (judge_tier 'free').
PROVY_KEY_SUPPORT=
PROVY_KEY_CLAIMS=
PROVY_KEY_CRM=

# Turn emission ON. Off (unset/0) = dry run: payloads are built + ground truth is
# recorded, but nothing hits the network. GitHub Actions auto-enables emission.
PROVY_EMIT=

# Free LLM for the agents + the L4 judge. Without it, the harness uses a
# deterministic offline stub so dry runs and tests still work.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — only to score the DETECTED side of the scoreboard (read-only ag_*).
SUPABASE_URL=
SUPABASE_KEY=
PROVY_TENANT_ID=
PROVY_WORKFLOW_ID=
